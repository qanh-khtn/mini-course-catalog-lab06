@model CourseEditViewModel

@{
    ViewData["Title"] = "Sửa Khóa Học";
}

<div class="container py-4 course-page">
    <div class="page-header">
        <div>
            <h2 class="page-title">Sửa Khóa Học</h2>
            <p class="page-description">Cập nhật thông tin lớp học. Hệ thống tự động xử lý xung đột nếu có người khác đang sửa cùng lúc.</p>
        </div>

        <a asp-controller="Courses" asp-action="Index"
           class="btn app-btn app-btn-ghost fw-bold px-4">
            <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
        </a>
    </div>

    <div class="card shadow-sm rounded-4 p-4 create-course-card">
        <form asp-controller="Courses" asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RowVersion" />
            <input type="hidden" asp-for="ExistingThumbnailPath" />

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Code" class="form-label fw-bold"></label>
                    <input asp-for="Code" class="form-control search-input" />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Name" class="form-label fw-bold"></label>
                    <input asp-for="Name" class="form-control search-input" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="CourseCategoryId" class="form-label fw-bold"></label>
                    <select asp-for="CourseCategoryId" asp-items="Model.CategoryOptions" class="form-select search-input">
                        <option value="0">-- Chọn chuyên ngành --</option>
                    </select>
                    <span asp-validation-for="CourseCategoryId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Instructor" class="form-label fw-bold"></label>
                    <input asp-for="Instructor" class="form-control search-input" />
                    <span asp-validation-for="Instructor" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="TuitionFee" class="form-label fw-bold"></label>
                    <input type="text" id="TuitionFeeDisplay" class="form-control search-input"
                           inputmode="numeric" autocomplete="off" placeholder="VD: 2,500,000" />
                    <input asp-for="TuitionFee" type="hidden" />
                    <span asp-validation-for="TuitionFee" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="CurrentEnrollment" class="form-label fw-bold"></label>
                    <input asp-for="CurrentEnrollment" class="form-control search-input" />
                    <span asp-validation-for="CurrentEnrollment" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="MaxCapacity" class="form-label fw-bold"></label>
                    <input asp-for="MaxCapacity" class="form-control search-input" />
                    <span asp-validation-for="MaxCapacity" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label fw-bold"></label>
                    <input asp-for="StartDate" type="date" class="form-control form-control-lg search-input" />
                    <span asp-validation-for="StartDate" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold">Ảnh thumbnail</label>
                    @if (!string.IsNullOrEmpty(Model.ExistingThumbnailPath))
                    {
                        <div class="mb-2">
                            <img src="@Model.ExistingThumbnailPath" alt="Thumbnail" class="img-thumbnail" style="max-height: 100px;" />
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-2">Chưa có ảnh thumbnail.</p>
                    }
                </div>
            </div>

            <div class="mt-4 d-flex flex-wrap gap-2">
                <button type="submit" class="btn app-btn app-btn-primary fw-bold px-4">
                    <i class="bi bi-check-circle me-2"></i>Lưu thay đổi
                </button>
                <a asp-controller="Courses" asp-action="Index"
                   class="btn app-btn app-btn-ghost fw-bold px-4">
                    <i class="bi bi-x-circle me-2"></i>Hủy
                </a>
            </div>
        </form>

        @if (User.IsInRole("Admin"))
        {
            <div class="card shadow-sm rounded-4 p-4 mt-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-image me-2"></i>Thay ảnh thumbnail</h5>
                <form asp-controller="Courses" asp-action="UploadThumbnail" asp-route-id="@Model.Id"
                      method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="row g-3 align-items-end">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Chọn ảnh mới (.jpg, .png, .webp — tối đa 2MB)</label>
                            <input type="file" name="thumbnail" accept=".jpg,.jpeg,.png,.webp" class="form-control search-input" required />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn app-btn app-btn-primary fw-bold w-100">
                                <i class="bi bi-upload me-2"></i>Tải lên
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_MoneyInputScript" />
}
