@model PaginationViewModel<CourseCatalogItemViewModel>
@{
    ViewData["Title"] = "Danh Mục Khóa Học";
}

<div class="container py-5">
    <div class="row align-items-end mb-5">
        <div class="col-lg-8">
            <p class="text-primary fw-bold small text-uppercase mb-2 tracking-wider">
                <i class="bi bi-mortarboard-fill me-2"></i>Mini Training Center
            </p>
            <h1 class="fw-extrabold mb-3" style="font-size:2.4rem;letter-spacing:-1px;">
                Danh Mục Khóa Học
            </h1>
            <p class="text-muted fs-6 mb-0" style="max-width:520px;">
                Khám phá các lớp học đang tuyển sinh — thông tin minh bạch, không cần đăng nhập.
            </p>
        </div>
        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
            <span class="badge bg-primary-subtle text-primary rounded-pill px-4 py-2 fw-bold fs-6">
                @Model.TotalItems khóa học
            </span>
        </div>
    </div>

    @if (!Model.Items.Any())
    {
        <partial name="~/Views/Shared/_EmptyState.cshtml" model='@("Chưa có khóa học nào. Vui lòng quay lại sau.")' />
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
            @foreach (var item in Model.Items)
            {
                <div>
                    <div class="card course-card h-100 rounded-4 shadow-sm border-0 overflow-hidden">
                        @* Thumbnail *@
                        <div class="position-relative" style="height:180px;overflow:hidden;background:linear-gradient(135deg,#e0f2fe,#eef2ff);">
                            @if (!string.IsNullOrEmpty(item.ThumbnailPath))
                            {
                                <img src="@item.ThumbnailPath" alt="@item.Name"
                                     class="w-100 h-100"
                                     style="object-fit:cover;"
                                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                <div class="w-100 h-100 d-none align-items-center justify-content-center position-absolute top-0 start-0"
                                     style="background:linear-gradient(135deg,#e0f2fe,#eef2ff);">
                                    <i class="bi bi-journal-text text-primary opacity-25" style="font-size:4rem;"></i>
                                </div>
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                                    <i class="bi bi-journal-text text-primary opacity-25" style="font-size:4rem;"></i>
                                </div>
                            }
                            @if (item.IsFull)
                            {
                                <span class="position-absolute top-0 end-0 m-2 badge bg-danger rounded-pill small">Hết chỗ</span>
                            }
                            else if (item.AvailableSeats <= 3)
                            {
                                <span class="position-absolute top-0 end-0 m-2 badge bg-warning text-dark rounded-pill small">Sắp hết</span>
                            }
                        </div>

                        <div class="card-body p-4 d-flex flex-column">
                            <div class="mb-2">
                                <span class="badge bg-secondary-subtle text-secondary rounded-pill small px-3 py-1">@item.Category</span>
                            </div>
                            <h5 class="fw-bold mb-1 lh-sm">@item.Name</h5>
                            <div class="text-muted small mb-3">
                                <i class="bi bi-person-fill me-1"></i>@item.Instructor
                            </div>

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-2 small">
                                    <span class="text-muted"><i class="bi bi-calendar3 me-1"></i>@item.StartDateText</span>
                                    <span class="@(item.IsFull ? "text-danger fw-bold" : "text-success fw-bold")">
                                        @(item.IsFull ? "Hết chỗ" : $"{item.AvailableSeats} chỗ còn")
                                    </span>
                                </div>
                                <div class="fw-extrabold text-primary" style="font-size:1.15rem;">@item.TuitionFeeText</div>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-0 px-4 pb-4">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a asp-controller="Courses" asp-action="Detail" asp-route-id="@item.Id"
                                   class="btn app-btn app-btn-primary fw-bold w-100">
                                    Xem chi tiết
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Courses" asp-action="Detail" asp-route-id="@item.Id"
                                   class="btn app-btn app-btn-soft fw-bold w-100">
                                    Xem chi tiết
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-5">
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm gap-2">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link rounded-circle border-0 d-flex align-items-center justify-content-center" 
                               style="width: 36px; height: 36px;"
                               asp-action="Catalog" asp-route-page="@(Model.CurrentPage - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link rounded-circle border-0 d-flex align-items-center justify-content-center fw-bold"
                                   style="width: 36px; height: 36px; @(i == Model.CurrentPage ? "background: var(--accent); color: white;" : "color: var(--text-muted);")"
                                   asp-action="Catalog" asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link rounded-circle border-0 d-flex align-items-center justify-content-center" 
                               style="width: 36px; height: 36px;"
                               asp-action="Catalog" asp-route-page="@(Model.CurrentPage + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>
