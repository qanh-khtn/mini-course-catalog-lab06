@model EnrollViewModel
@{
    ViewData["Title"] = "Đăng Ký Khóa Học";
    var theme = ViewData["Theme"]?.ToString() ?? "light";
}

<div class="py-2">
    <div class="page-header mb-4">
        <div>
            <h1 class="page-title">Đăng Ký Khóa Học</h1>
            <p class="page-description">Đăng ký học viên vào khóa học. Hệ thống tự động kiểm tra số chỗ trống trước khi xác nhận.</p>
        </div>
        <a asp-controller="Enrollments" asp-action="History" class="btn app-btn app-btn-ghost fw-bold px-4">
            <i class="bi bi-clock-history me-2"></i>Lịch sử đăng ký
        </a>
    </div>

    @if (Model.IsSuccess.HasValue)
    {
        <div class="alert @(Model.IsSuccess.Value ? "alert-success" : "alert-danger") alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
            <i class="bi @(Model.IsSuccess.Value ? "bi-check-circle-fill" : "bi-x-circle-fill") me-2"></i>
            @Model.ResultMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 p-4" style="max-width:560px;">
        <form asp-controller="Courses" asp-action="Enroll" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="theme" value="@theme" />
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="CourseId" class="form-label">Khóa học</label>
                <select asp-for="CourseId" asp-items="Model.CourseOptions" class="form-select">
                    <option value="0">-- Chọn khóa học --</option>
                </select>
                <span asp-validation-for="CourseId" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="StudentId" class="form-label">Học viên</label>
                <select asp-for="StudentId" asp-items="Model.StudentOptions" class="form-select">
                    <option value="0">-- Chọn học viên --</option>
                </select>
                <span asp-validation-for="StudentId" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn app-btn app-btn-primary fw-bold px-4">
                    <i class="bi bi-person-check me-2"></i>Đăng ký
                </button>
                <a asp-controller="Courses" asp-action="Index" asp-route-theme="@theme" class="btn app-btn app-btn-ghost fw-bold px-4">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
