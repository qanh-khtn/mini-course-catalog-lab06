@model CourseDetailViewModel
@{
    ViewData["Title"] = "Chi Tiết Khóa Học";

    var statusClass = (Model.CurrentEnrollment >= Model.MaxCapacity)          ? "badge bg-danger" :
                      (Model.MaxCapacity - Model.CurrentEnrollment <= 3)       ? "badge bg-warning text-dark" :
                      (Model.CurrentEnrollment < 10)                           ? "badge bg-secondary" :
                                                                                 "badge bg-success";
}

<div class="py-2">
    <div class="page-header mb-4">
        <div>
            <div class="text-muted small mb-1 fw-mono">@Model.Code</div>
            <h1 class="page-title">@Model.Name</h1>
            <p class="page-description">@Model.Category</p>
        </div>
        <a class="btn app-btn app-btn-ghost fw-bold px-4"
           asp-controller="Courses" asp-action="Index">
            <i class="bi bi-arrow-left me-2"></i>Quay lại
        </a>
    </div>

    <div class="row g-4 align-items-start">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h6 class="fw-bold text-muted text-uppercase mb-3" style="letter-spacing:.05em;font-size:.75rem;">
                    <i class="bi bi-info-circle me-2"></i>Thông tin lớp học
                </h6>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="text-muted small">Mã khóa học</div>
                        <div class="fw-bold text-primary fs-5 fw-mono">@Model.Code</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small">Mã hệ thống</div>
                        <div class="fw-bold text-dark">#@Model.Id</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small">Giảng viên phụ trách</div>
                        <div class="fw-bold text-dark"><i class="bi bi-person-fill text-muted me-1"></i>@Model.Instructor</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small">Chuyên ngành</div>
                        <div class="fw-bold">
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3">@Model.Category</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small">Ngày khai giảng</div>
                        <div class="fw-bold text-dark"><i class="bi bi-calendar3 text-muted me-1"></i>@Model.StartDateText</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small">Trạng thái</div>
                        <div class="mt-1">
                            <span class="@statusClass px-3 py-1 rounded-pill small">@Model.CourseStatus</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h6 class="fw-bold text-muted text-uppercase mb-3" style="letter-spacing:.05em;font-size:.75rem;">
                    <i class="bi bi-people me-2"></i>Tuyển sinh & Học phí
                </h6>
                <div class="row g-3">
                    <div class="col-sm-4">
                        <div class="stat-card">
                            <div class="stat-number text-primary">@Model.CurrentEnrollment</div>
                            <div class="stat-label">Học viên hiện tại</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="stat-card">
                            <div class="stat-number text-secondary">@Model.MaxCapacity</div>
                            <div class="stat-label">Sức chứa tối đa</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="stat-card">
                            <div class="stat-number" style="color:#10b981;">@Model.MaxCapacity - @Model.CurrentEnrollment</div>
                            <div class="stat-label">Còn trống</div>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    @{
                        var fillPct = Model.MaxCapacity > 0 ? (int)Math.Round((double)Model.CurrentEnrollment / Model.MaxCapacity * 100) : 0;
                        var barColor = fillPct >= 100 ? "bg-danger" : fillPct >= 80 ? "bg-warning" : "bg-primary";
                    }
                    <div class="d-flex justify-content-between mb-1 small text-muted">
                        <span>Tỷ lệ lấp đầy</span>
                        <span class="fw-bold">@fillPct%</span>
                    </div>
                    <div class="progress rounded-pill" style="height:10px;">
                        <div class="progress-bar @barColor" style="width:@(fillPct.ToString(System.Globalization.CultureInfo.InvariantCulture))%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-3 side-card success">
                <div class="text-muted small text-uppercase fw-bold mb-1" style="letter-spacing:.05em;font-size:.72rem;">
                    <i class="bi bi-cash-coin me-1"></i>Học phí / suất
                </div>
                <div class="fw-extrabold" style="font-size:1.6rem;color:#059669;">@Model.TuitionFeeText</div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-4 mb-3 side-card info">
                <div class="text-muted small text-uppercase fw-bold mb-1" style="letter-spacing:.05em;font-size:.72rem;">
                    <i class="bi bi-wallet2 me-1"></i>Doanh thu hiện tại
                </div>
                <div class="fw-extrabold text-primary" style="font-size:1.6rem;">@Model.TotalRevenueText</div>
                <div class="text-muted small mt-1">Dựa trên @Model.CurrentEnrollment học viên × @Model.TuitionFeeText</div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-4 side-card warning">
                <div class="text-muted small text-uppercase fw-bold mb-2" style="letter-spacing:.05em;font-size:.72rem;">
                    <i class="bi bi-lightbulb me-1"></i>Gợi ý vận hành
                </div>
                <div class="small text-dark">@Model.OperationalSuggestion</div>
            </div>

            <div class="mt-3 d-flex flex-column gap-2">
                <a asp-controller="Courses" asp-action="Enroll" class="btn app-btn app-btn-primary fw-bold px-4">
                    <i class="bi bi-person-plus me-2"></i>Đăng ký học viên
                </a>
                <a asp-controller="Courses" asp-action="Index" class="btn app-btn app-btn-ghost fw-bold px-4">
                    <i class="bi bi-arrow-left me-2"></i>Về danh sách
                </a>
            </div>
        </div>

        <!-- Reviews Section -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mt-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold text-muted text-uppercase mb-0" style="letter-spacing:.05em;font-size:.75rem;">
                    <i class="bi bi-star me-2"></i>Đánh giá từ học viên
                </h6>
                @if (Model.ReviewCount > 0)
                {
                    <div class="d-flex align-items-center gap-2">
                        <span class="fs-5 fw-bold text-dark">@Model.AverageRating.ToString("0.0")</span>
                        <div class="text-warning">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= Math.Round(Model.AverageRating) ? "bi-star-fill" : "bi-star")"></i>
                            }
                        </div>
                        <span class="text-muted small">(@Model.ReviewCount đánh giá)</span>
                    </div>
                }
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-action="AddReview" method="post" class="mb-4 pb-4 border-bottom">
                    <input type="hidden" name="courseId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Đánh giá của bạn</label>
                        <div class="rating-input d-flex gap-2 text-warning fs-5">
                            <div class="form-check form-check-inline m-0 p-0">
                                <input type="radio" class="btn-check" name="rating" id="rating5" value="5" autocomplete="off" checked>
                                <label class="btn btn-outline-warning border-0 p-1" for="rating5"><i class="bi bi-star-fill"></i> 5</label>
                            </div>
                            <div class="form-check form-check-inline m-0 p-0">
                                <input type="radio" class="btn-check" name="rating" id="rating4" value="4" autocomplete="off">
                                <label class="btn btn-outline-warning border-0 p-1" for="rating4"><i class="bi bi-star-fill"></i> 4</label>
                            </div>
                            <div class="form-check form-check-inline m-0 p-0">
                                <input type="radio" class="btn-check" name="rating" id="rating3" value="3" autocomplete="off">
                                <label class="btn btn-outline-warning border-0 p-1" for="rating3"><i class="bi bi-star-fill"></i> 3</label>
                            </div>
                            <div class="form-check form-check-inline m-0 p-0">
                                <input type="radio" class="btn-check" name="rating" id="rating2" value="2" autocomplete="off">
                                <label class="btn btn-outline-warning border-0 p-1" for="rating2"><i class="bi bi-star-fill"></i> 2</label>
                            </div>
                            <div class="form-check form-check-inline m-0 p-0">
                                <input type="radio" class="btn-check" name="rating" id="rating1" value="1" autocomplete="off">
                                <label class="btn btn-outline-warning border-0 p-1" for="rating1"><i class="bi bi-star-fill"></i> 1</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="comment" class="form-label small fw-bold">Nhận xét (không bắt buộc)</label>
                        <textarea class="form-control bg-light border-0" id="comment" name="comment" rows="2" placeholder="Chia sẻ cảm nhận của bạn về khóa học..."></textarea>
                    </div>
                    <button type="submit" class="btn app-btn app-btn-primary fw-bold px-4">Gửi đánh giá</button>
                </form>
            }
            else
            {
                <div class="alert bg-light border-0 text-center mb-4 rounded-4">
                    <a asp-controller="Account" asp-action="Login" class="fw-bold">Đăng nhập</a> để gửi đánh giá khóa học.
                </div>
            }

            @if (Model.Reviews.Any())
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="d-flex gap-3">
                            <div class="avatar bg-secondary-subtle text-dark fw-bold rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                @(review.User?.FullName?.FirstOrDefault().ToString() ?? review.User?.UserName?.FirstOrDefault().ToString() ?? "U")
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div class="fw-bold">@(review.User?.FullName ?? review.User?.UserName ?? "Học viên ẩn danh")</div>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="text-muted small">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form method="post" asp-action="HideReview" asp-route-id="@review.Id" class="m-0 p-0">
                                                <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Ẩn đánh giá">
                                                    <i class="bi bi-eye-slash-fill"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                                <div class="text-warning small mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star")"></i>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <p class="mb-0 text-dark small">@review.Comment</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-chat-square-text fs-1 mb-2 text-secondary opacity-50"></i>
                    <p class="mb-0 small">Chưa có đánh giá nào cho khóa học này.</p>
                </div>
            }
        </div>
    </div>
</div>
