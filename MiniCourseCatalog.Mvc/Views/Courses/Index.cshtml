@model CourseIndexViewModel
@{
    ViewData["Title"] = "Danh Mục Khóa Học";
}

<div class="container py-4 course-page">
    <div class="row align-items-center mb-4">
        <div class="col-md-7">
            <h2 class="fw-extrabold m-0" style="letter-spacing: -1px;">Danh Mục Khóa Học</h2>
            <p class="text-muted m-0 mt-1">Hệ thống quản lý thông tin giảng dạy và điều phối sĩ số lớp học trực quan.</p>
        </div>
        <div class="col-md-5 text-md-end mt-3 mt-md-0 d-flex flex-wrap gap-2 justify-content-md-end">
            <a class="btn app-btn app-btn-ghost shadow-sm fw-bold px-4 py-2" asp-controller="Courses" asp-action="Export"><i class="bi bi-filetype-csv me-2"></i>Xuất CSV</a>
            <a class="btn app-btn app-btn-primary shadow-sm fw-bold px-4 py-2" asp-controller="Courses" asp-action="Stats"><i class="bi bi-bar-chart-fill me-2"></i>Báo Cáo</a>
        </div>
    </div>


    <partial name="~/Views/Shared/_SearchFilterForm.cshtml" model="Model" />

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div><h5 class="fw-bold mb-1">Danh sách lớp học vận hành</h5><p class="text-muted mb-0">Danh sách các khóa học đang tuyển sinh.</p></div>
        <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 fw-bold">@Model.Courses.TotalItems/@Model.TotalCoursesBeforeFilter lớp</span>
    </div>

    <div id="loadingIndicator" class="d-none" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
        @for(int i = 0; i < 4; i++) {
            <div><partial name="~/Views/Shared/_SkeletonCard.cshtml" /></div>
        }
    </div>

    <div id="courseList">
        @if (Model.Courses.TotalItems == 0)
        {
            <partial name="~/Views/Shared/_EmptyState.cshtml" model='@("Không tìm thấy khóa học. Thử đổi từ khóa hoặc chọn lại chuyên ngành.")' />
        }
        else
        {
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
                @foreach (var item in Model.Courses.Items)
                {
                    <div><partial name="~/Views/Shared/_CourseCard.cshtml" model="item" /></div>
                }
            </div>

            @if (Model.Courses.TotalPages > 1)
            {
                <div class="d-flex justify-content-center mt-5">
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm gap-2">
                            @for (int i = 1; i <= Model.Courses.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Courses.CurrentPage ? "active" : "")">
                                    <a class="page-link rounded-circle border-0 d-flex align-items-center justify-content-center fw-bold"
                                       style="width: 36px; height: 36px; @(i == Model.Courses.CurrentPage ? "background: var(--accent); color: white;" : "color: var(--text-muted);")"
                                       asp-action="Index" 
                                       asp-route-keyword="@Model.Keyword" 
                                       asp-route-category="@Model.Category" 
                                       asp-route-page="@i">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script nonce="@Context.Items["csp-nonce"]">
        document.addEventListener("DOMContentLoaded", function() {
            var filterForm = document.querySelector(".filter-panel form");
            if (filterForm) {
                filterForm.addEventListener("submit", function() {
                    document.getElementById("courseList").classList.add("d-none");
                    document.getElementById("loadingIndicator").classList.remove("d-none");
                });
            }
        });
    </script>
}
