@model CourseSearchViewModel

@{
    ViewData["Title"] = "Tìm Kiếm Khóa Học";
}

<div class="container py-4 course-page">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <h2 class="fw-bold mb-0"><i class="bi bi-search text-primary me-2"></i>Tìm Kiếm Khóa Học</h2>
        <a asp-controller="Courses" asp-action="Index" class="btn app-btn app-btn-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Danh sách
        </a>
    </div>

    <!-- Hero Search -->
    <div class="card border-0 shadow-sm rounded-4 mb-5" style="background: var(--surface);">
        <div class="card-body p-4 p-md-5 text-center">
            <h4 class="fw-bold mb-4">Bạn muốn học gì hôm nay?</h4>
            
            <form asp-controller="Courses" asp-action="Search" method="get" class="mx-auto" style="max-width: 700px;">
                
                <div class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden border" style="background: var(--app-bg)">
                    <span class="input-group-text bg-transparent border-0 text-muted ps-4">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="keyword" value="@Model.Keyword" class="form-control border-0 bg-transparent shadow-none px-2" placeholder="Tên khóa học, mã lớp, giảng viên..." style="font-size: 1rem;" />
                    <select name="category" class="form-select border-0 border-start bg-transparent shadow-none" style="max-width: 200px; font-size: 0.95rem;">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category" selected="@(Model.Category == category)">@category</option>
                        }
                    </select>
                    <button type="submit" class="btn app-btn app-btn-primary px-4 fw-bold">Tìm kiếm</button>
                </div>
                
                <div class="mt-4 d-flex flex-wrap justify-content-center gap-2 align-items-center text-muted small">
                    <span class="fw-semibold me-2">Gợi ý:</span>
                    @foreach (var cat in Model.Categories.Take(4))
                    {
                        <a href="@Url.Action("Search", new { category = cat })" class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary text-decoration-none px-3 py-2 border hover-shadow-sm transition-all">@cat</a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Results -->
    <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
        <h5 class="fw-bold mb-0">Kết quả tìm kiếm</h5>
        @if (Model.Results.Any())
        {
            <span class="badge bg-primary rounded-pill">@Model.Results.Count khóa học</span>
        }
    </div>

    @if (!Model.Results.Any() && string.IsNullOrEmpty(Model.Keyword) && string.IsNullOrEmpty(Model.Category))
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-search fs-1 d-block mb-3 opacity-25"></i>
            <p>Nhập từ khóa hoặc chọn danh mục để bắt đầu tìm kiếm.</p>
        </div>
    }
    else if (!Model.Results.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
            <p>Không tìm thấy khóa học nào khớp với tìm kiếm của bạn.</p>
        </div>
    }
    else
    {
        <partial name="~/Views/Shared/_CourseSearchResultList.cshtml" model="Model.Results" />
    }
</div>