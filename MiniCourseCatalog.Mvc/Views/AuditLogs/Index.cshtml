@model AuditLogSearchViewModel

@{
    ViewData["Title"] = "Audit Logs";
}

<div class="container py-4">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title">Nhật Ký Hệ Thống (Audit Logs)</h2>
            <p class="page-description text-muted">Tra cứu lịch sử thao tác của người dùng.</p>
        </div>
    </div>

    <div class="border-top pt-4 pb-2 mb-4">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label asp-for="User" class="form-label fw-bold"></label>
                <input asp-for="User" class="form-control search-input" placeholder="admin@coursecenter.test" />
            </div>
            <div class="col-md-3">
                <label asp-for="ActionName" class="form-label fw-bold"></label>
                <input asp-for="ActionName" class="form-control search-input" placeholder="AdjustSeats" />
            </div>
            <div class="col-md-2">
                <label asp-for="Result" class="form-label fw-bold"></label>
                <select asp-for="Result" class="form-select search-input">
                    <option value="">-- Tất cả --</option>
                    <option value="Success">Success</option>
                    <option value="Fail">Fail</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="FromDate" class="form-label fw-bold"></label>
                <input asp-for="FromDate" class="form-control search-input" />
            </div>
            <div class="col-md-2">
                <label asp-for="ToDate" class="form-label fw-bold"></label>
                <input asp-for="ToDate" class="form-control search-input" />
            </div>
            <div class="col-12 d-flex justify-content-end">
                <button type="submit" class="btn app-btn app-btn-primary px-4 fw-bold">
                    <i class="bi bi-search me-2"></i>Tìm kiếm
                </button>
            </div>
        </form>
    </div>

    <div class="border-top pt-3">
        @if (Model.Logs.TotalItems > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Thời gian (UTC)</th>
                            <th>Action</th>
                            <th>Thực thể</th>
                            <th>User</th>
                            <th>IP</th>
                            <th>Kết quả</th>
                            <th>Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.Logs.Items)
                        {
                            <tr>
                                <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td><span class="badge bg-secondary">@log.Action</span></td>
                                <td>
                                    @log.EntityName 
                                    @if (!string.IsNullOrEmpty(log.EntityId)) { <span class="text-muted">(@log.EntityId)</span> }
                                </td>
                                <td>@log.UserName</td>
                                <td>@log.IpAddress</td>
                                <td>
                                    @if (log.Result == "Success")
                                    {
                                        <span class="badge bg-success">@log.Result</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@log.Result</span>
                                    }
                                </td>
                                <td class="text-muted small">@log.Note</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.Logs.TotalPages > 1)
            {
                <div class="d-flex justify-content-center p-3 border-top">
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0 gap-2">
                            @for (int i = 1; i <= Model.Logs.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Logs.CurrentPage ? "active" : "")">
                                    <a class="page-link rounded-circle border-0 d-flex align-items-center justify-content-center fw-bold"
                                       style="width: 32px; height: 32px; @(i == Model.Logs.CurrentPage ? "background: var(--accent); color: white;" : "color: var(--text-muted);")"
                                       asp-action="Index" 
                                       asp-route-User="@Model.User" 
                                       asp-route-ActionName="@Model.ActionName"
                                       asp-route-Result="@Model.Result"
                                       asp-route-FromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                                       asp-route-ToDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                                       asp-route-page="@i">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        }
        else
        {
            <partial name="~/Views/Shared/_EmptyState.cshtml" model='@("Không có bản ghi phù hợp.")' />
        }
    </div>
</div>
