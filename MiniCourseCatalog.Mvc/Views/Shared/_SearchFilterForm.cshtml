@model CourseIndexViewModel
@{
    var currentTheme = Model.Theme;
}

<div class="card filter-panel shadow-sm rounded-4 mb-4">
    <div class="card-body p-3 p-md-4">
        <form asp-controller="Courses" asp-action="Index" method="get" class="row g-3 align-items-end">
            <input type="hidden" name="theme" value="@currentTheme" />

            <div class="col-md-5">
                <label class="form-label small fw-bold text-uppercase text-muted">Tìm kiếm</label>
                <input class="form-control form-control-lg search-input"
                       name="keyword"
                       value="@Model.Keyword"
                       placeholder="Tên khóa học, mã lớp, giảng viên..." />
            </div>

            <div class="col-md-4">
                <label class="form-label small fw-bold text-uppercase text-muted">Chuyên ngành</label>
                <select class="form-select form-select-lg search-input" name="category">
                    <option value="">Tất cả chuyên ngành</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category" selected="@(Model.Category == category)">@category</option>
                    }
                </select>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button class="btn app-btn app-btn-primary flex-fill fw-bold" type="submit">
                    <i class="bi bi-search me-2"></i>Lọc
                </button>

                <a class="btn app-btn app-btn-ghost fw-bold"
                   asp-controller="Courses"
                   asp-action="Index"
                   asp-route-theme="@currentTheme">
                    Xóa
                </a>
            </div>
        </form>
    </div>
</div>