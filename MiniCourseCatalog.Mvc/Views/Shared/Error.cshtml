@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi hệ thống";
}

<div class="container py-5 d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 250px);">
    <div class="card border-0 shadow-lg rounded-4 p-5 text-center" style="max-width: 600px; background: var(--surface); border: 1px solid var(--border) !important;">
        <div class="rounded-circle p-4 bg-danger bg-opacity-10 text-danger mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
            <i class="bi bi-exclamation-octagon fs-1"></i>
        </div>
        <h2 class="fw-bold mb-3 text-danger">Đã xảy ra lỗi</h2>
        <p class="text-secondary mb-4">Hệ thống gặp sự cố không mong muốn khi xử lý yêu cầu của bạn.</p>

        @if (Model.ShowRequestId)
        {
            <div class="rounded-3 p-3 text-start mb-4 border" style="font-size: 0.9rem; background: var(--bg-surface-hover); border-color: var(--border) !important;">
                <div class="text-secondary">
                    <span class="fw-semibold">Mã yêu cầu (Request ID):</span> 
                    <code class="fw-mono text-danger bg-danger bg-opacity-10 px-2 py-0.5 rounded d-block mt-1 text-break">@Model.RequestId</code>
                </div>
            </div>
        }

        <p class="text-muted small mb-4">Nếu lỗi này tiếp tục xảy ra, vui lòng liên hệ quản trị viên hệ thống cùng mã Request ID ở trên.</p>

        <div class="d-flex gap-2 justify-content-center">
            <a asp-controller="Home" asp-action="Index" class="btn app-btn app-btn-primary px-4">
                <i class="bi bi-house-door me-2"></i>Trang chủ
            </a>
            <button id="btnBack" class="btn app-btn app-btn-ghost px-4">
                <i class="bi bi-arrow-left me-2"></i>Quay lại
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.Items["csp-nonce"]">
        document.getElementById('btnBack').addEventListener('click', function () {
            window.history.back();
        });
    </script>
}
