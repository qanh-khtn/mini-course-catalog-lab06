@model List<CourseListItemViewModel>

@if (Model.Count == 0)
{
    <partial name="~/Views/Shared/_EmptyState.cshtml" model='@("Không tìm thấy khóa học phù hợp. Vui lòng thử từ khóa khác.")' />
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6">
                <partial name="~/Views/Shared/_CourseCard.cshtml" model="item" />
            </div>
        }
    </div>
}