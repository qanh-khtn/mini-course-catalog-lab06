@model List<CourseListItemViewModel>

@if (Model.Count == 0)
{
    <div class="alert alert-warning rounded-4 shadow-sm border-0 p-4">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        Không tìm thấy khóa học phù hợp. Vui lòng thử từ khóa khác.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6">
                <partial name="~/Views/Shared/_CourseCard.cshtml" model="item" />
            </div>
        }
    </div>
}