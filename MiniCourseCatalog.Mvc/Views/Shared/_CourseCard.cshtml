@model CourseListItemViewModel

@{
    var theme = ViewData["Theme"]?.ToString() ?? "light";
    // Mỗi chuyên ngành một dải màu nhận diện riêng (cat-0..cat-5)
    var catClass = "cat-" + (Math.Abs(Model.Category.GetHashCode()) % 6);
    var fillRate = Model.MaxCapacity > 0
        ? (int)Math.Round(100.0 * Model.CurrentEnrollment / Model.MaxCapacity) : 0;
    var barClass = fillRate >= 100 ? "bg-danger" : fillRate >= 80 ? "bg-warning" : "bg-success";
}

<div class="card course-card h-100 rounded-4 shadow-sm position-relative @catClass">
    <div class="card-accent"></div>
    <div class="card-body p-4 d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
            <div>
                <div class="fw-bold text-primary small">@Model.Code</div>
                <h5 class="fw-bold mb-1">
                    <a asp-controller="Courses" asp-action="Detail"
                       asp-route-id="@Model.Id" asp-route-theme="@theme"
                       class="stretched-link text-decoration-none text-reset">@Model.Name</a>
                </h5>
                <div class="text-muted small">@Model.Category</div>
            </div>

            <partial name="~/Views/Courses/_CourseStatusBadge.cshtml" model="Model" />
        </div>

        <div class="small mb-3">
            <span class="text-muted">Giảng viên:</span>
            <span class="fw-bold">@Model.Instructor</span>
        </div>

        <div class="mb-3">
            <div class="d-flex justify-content-between small mb-1">
                <span class="text-muted">Sĩ số</span>
                <span class="fw-bold">@Model.EnrollmentStatus · @fillRate%</span>
            </div>
            <div class="progress seat-progress">
                <div class="progress-bar @barClass" role="progressbar"
                     style="width: @fillRate%"
                     aria-valuenow="@fillRate" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
        </div>

        <div class="mt-auto d-flex justify-content-between align-items-center gap-2">
            <span class="course-price-tag">@Model.TuitionFeeText</span>

            @* position-relative + z-index để nút nổi lên trên stretched-link của tiêu đề *@
            <div class="d-flex gap-1 position-relative" style="z-index: 2;">
                <a asp-controller="Courses" asp-action="Edit"
                   asp-route-id="@Model.Id" asp-route-theme="@theme"
                   class="btn btn-sm btn-outline-primary" title="Sửa">
                    <i class="bi bi-pencil"></i>
                </a>
                <a asp-controller="Courses" asp-action="AdjustSeats"
                   asp-route-id="@Model.Id" asp-route-theme="@theme"
                   class="btn btn-sm btn-outline-secondary" title="Điều chỉnh sĩ số">
                    <i class="bi bi-people"></i>
                </a>
                <a asp-controller="Courses" asp-action="Delete"
                   asp-route-id="@Model.Id" asp-route-theme="@theme"
                   class="btn btn-sm btn-outline-danger" title="Xóa">
                    <i class="bi bi-trash"></i>
                </a>
            </div>
        </div>
    </div>
</div>
