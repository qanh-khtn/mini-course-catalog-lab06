@model MiniCourseCatalog.Mvc.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo-icon">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h3 class="auth-title">Chào Mừng Trở Lại</h3>
            <p class="auth-subtitle">Đăng nhập vào hệ thống Mini Training Center</p>
        </div>
        
        <div class="auth-body">
            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="auth-input-group">
                    <input asp-for="Email" class="auth-input w-100" placeholder="Địa chỉ email" autocomplete="username" />
                    <i class="bi bi-envelope auth-icon"></i>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                
                <div class="auth-input-group">
                    <input asp-for="Password" type="password" class="auth-input w-100" placeholder="Mật khẩu" autocomplete="current-password" />
                    <i class="bi bi-key auth-icon"></i>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                
                <button type="submit" class="auth-btn mt-2">Đăng nhập</button>
            </form>
        </div>
        
        <div class="auth-footer border-top pt-4">
            <span class="text-muted">Chưa có tài khoản?</span>
            <a asp-action="Register" class="auth-link ms-1">Đăng ký ngay</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
