@model MiniCourseCatalog.Mvc.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo-icon">
                <i class="bi bi-person-plus-fill"></i>
            </div>
            <h3 class="auth-title">Đăng Ký Tài Khoản</h3>
            <p class="auth-subtitle">Trở thành học viên tại Mini Training Center</p>
        </div>
        
        <div class="auth-body">
            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="auth-input-group">
                    <input asp-for="FullName" class="auth-input w-100" placeholder="Họ và tên của bạn" />
                    <i class="bi bi-person auth-icon"></i>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                
                <div class="auth-input-group">
                    <input asp-for="Email" class="auth-input w-100" placeholder="Địa chỉ email" autocomplete="username" />
                    <i class="bi bi-envelope auth-icon"></i>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                
                <div class="auth-input-group">
                    <input asp-for="Password" type="password" class="auth-input w-100" placeholder="Mật khẩu" autocomplete="new-password" />
                    <i class="bi bi-key auth-icon"></i>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                
                <div class="auth-input-group">
                    <input asp-for="ConfirmPassword" type="password" class="auth-input w-100" placeholder="Xác nhận mật khẩu" autocomplete="new-password" />
                    <i class="bi bi-shield-check auth-icon"></i>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                
                <button type="submit" class="auth-btn mt-2">Đăng ký tài khoản</button>
            </form>
        </div>
        
        <div class="auth-footer border-top pt-4">
            <span class="text-muted">Đã có tài khoản?</span>
            <a asp-action="Login" class="auth-link ms-1">Đăng nhập</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
